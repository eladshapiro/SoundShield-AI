# =============================================================
# SoundShield-AI Configuration (.env.example)
# Version 2.0.0
# Copy this file to .env and customize values as needed.
# Uncommented values show defaults; commented lines are optional.
# =============================================================

# --- Audio Analyzer ---
# AUDIO_SAMPLE_RATE=22050
# AUDIO_CALIBRATION_SECONDS=30.0
# AUDIO_SILENCE_THRESHOLD_MIN=0.005
# AUDIO_SILENCE_THRESHOLD_MULTIPLIER=0.5
# AUDIO_LOUD_THRESHOLD_MIN=0.1
# AUDIO_LOUD_THRESHOLD_SIGMA=3.0
# AUDIO_DEFAULT_SILENCE_THRESHOLD=0.01
# AUDIO_DEFAULT_LOUD_THRESHOLD=0.3
# AUDIO_SEGMENT_LENGTH=5.0
# AUDIO_FRAME_LENGTH=2048
# AUDIO_HOP_LENGTH=512
# AUDIO_N_MFCC=13

# --- Cry Detector ---
# CRY_ENERGY_THRESHOLD=0.02
# CRY_FREQ_MIN=200
# CRY_FREQ_MAX=800
# CRY_PITCH_VARIANCE_THRESHOLD=0.15
# CRY_SPECTRAL_ROLLOFF_THRESHOLD=0.4
# CRY_ZCR_THRESHOLD=0.02
# CRY_INTENSITY_LOW_MAX=0.12
# CRY_INTENSITY_MEDIUM_MAX=0.2
# CRY_MIN_SCORE_RATIO=0.50
# CRY_VOICED_RATIO_THRESHOLD=0.3
# CRY_AM_DEPTH_THRESHOLD=0.15
# CRY_SPECTRAL_FLATNESS_THRESHOLD=0.3
# CRY_F0_STD_THRESHOLD=20.0
# CRY_RESPONSE_WINDOW=10.0
# CRY_MIN_RESPONSE_DURATION=1.0
# CRY_RESPONSE_ENERGY_THRESHOLD=0.05
# CRY_RESPONSE_PITCH_THRESHOLD=100
# CRY_RESPONSE_QUALITY_POOR_MAX=0.08
# CRY_RESPONSE_QUALITY_ADEQUATE_MAX=0.15

# --- Violence Detector ---
# VIOLENCE_MIN_ENERGY_GATE=0.05
# VIOLENCE_MERGE_GAP_SECONDS=1.5
# VIOLENCE_MAX_MERGED_DURATION=20.0
# VIOLENCE_SHOUTING_ENERGY=0.12
# VIOLENCE_SHOUTING_FREQ_VARIANCE=0.4
# VIOLENCE_SHOUTING_SPECTRAL_ROLLOFF=0.7
# VIOLENCE_SHOUTING_DURATION=0.3
# VIOLENCE_AGGRESSIVE_ENERGY=0.10
# VIOLENCE_AGGRESSIVE_PITCH_VARIANCE=0.35
# VIOLENCE_AGGRESSIVE_SPECTRAL_BW=0.6
# VIOLENCE_AGGRESSIVE_ZCR=0.08
# VIOLENCE_THREATENING_ENERGY=0.08
# VIOLENCE_THREATENING_FREQ_LOW=80
# VIOLENCE_THREATENING_CONTRAST=0.5
# VIOLENCE_THREATENING_DURATION=1.0
# VIOLENCE_PHYSICAL_ENERGY_SPIKE=0.4
# VIOLENCE_PHYSICAL_HF_CONTENT=0.8
# VIOLENCE_PHYSICAL_RAPID_CHANGES=0.6
# VIOLENCE_BEFORE_WINDOW=5.0
# VIOLENCE_AFTER_WINDOW=5.0
# VIOLENCE_SILENCE_AFTER=2.0
# VIOLENCE_CONTINUED_DISTRESS=10.0

# --- Emotion Detector ---
# EMOTION_CONFIDENCE_THRESHOLD=0.6
# EMOTION_MIN_SEGMENT_LENGTH=0.5
# EMOTION_ANGER_ENERGY=0.08
# EMOTION_ANGER_PITCH_VARIANCE=0.3
# EMOTION_ANGER_SPECTRAL_ROLLOFF=0.6
# EMOTION_STRESS_ENERGY_VARIANCE=0.03
# EMOTION_STRESS_ZCR=0.05
# EMOTION_STRESS_SC_VARIANCE=0.2
# EMOTION_CALM_ENERGY=0.01
# EMOTION_CALM_PITCH_STABILITY=0.8
# EMOTION_CALM_SPECTRAL_ROLLOFF=0.4
# EMOTION_AGGRESSION_ENERGY=0.2
# EMOTION_AGGRESSION_PITCH_VARIANCE=0.4
# EMOTION_AGGRESSION_SPECTRAL_BW=0.7

# --- Neglect Detector ---
# NEGLECT_UNANSWERED_CRY_DURATION=30.0
# NEGLECT_MIN_CRY_DURATION=5.0
# NEGLECT_RESPONSE_WINDOW=15.0
# NEGLECT_SILENCE_AFTER_DISTRESS=60.0
# NEGLECT_REPEATED_UNANSWERED=3
# NEGLECT_LONG_TERM_SILENCE=300.0
# NEGLECT_PROLONGED_SILENCE_DURATION=120.0
# NEGLECT_PROLONGED_SILENCE_ENERGY=0.02
# NEGLECT_ADULT_SPEECH_THRESHOLD=0.1
# NEGLECT_INTERACTION_WINDOW=3600.0
# NEGLECT_DISTRESS_DURATION=20.0
# NEGLECT_RESPONSE_ENERGY=0.08

# --- Inappropriate Language Detector ---
# LANGUAGE_WORDS_FILE=inappropriate_words.json
# LANGUAGE_DEFAULT=en

# --- Advanced Models ---
# USE_ADVANCED_MODELS=True
# WHISPER_MODEL=base
# HUBERT_MODEL=superb/hubert-large-superb-er
# ADVANCED_CHUNK_DURATION=7.0

# --- Security ---
# SECRET_KEY=change-this-in-production
# AUTH_ENABLED=False
# JWT_EXPIRY_HOURS=24
# RATE_LIMIT_DEFAULT=60/minute
# RATE_LIMIT_UPLOAD=10/minute
# RATE_LIMIT_API=120/minute
# ENABLE_SECURITY_HEADERS=True
# HSTS_MAX_AGE=31536000

# --- Web Application ---
# WEB_HOST=0.0.0.0
# WEB_PORT=5000
# WEB_DEBUG=True
# UPLOAD_FOLDER=uploads
# REPORTS_FOLDER=reports
# MAX_UPLOAD_SIZE_MB=500
# ANALYSIS_MAX_WORKERS=2
# CORS_ORIGINS=*

# --- Database ---
# DATABASE_PATH=soundshield.db
# DATA_RETENTION_DAYS=90

# --- Logging ---
# LOG_LEVEL=INFO
# LOG_FORMAT=json
# LOG_FILE=soundshield.log
# ENABLE_CORRELATION_ID=True

# --- Pipeline ---
# MAX_AUDIO_LENGTH=3600
# MIN_AUDIO_LENGTH=1
