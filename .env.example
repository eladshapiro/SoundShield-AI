# ============================================================
# SoundShield-AI Environment Configuration
# Copy this file to .env and customize values as needed
# ============================================================

# --- Web Server ---
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false
CORS_ORIGINS=*
# MAX_UPLOAD_SIZE_MB=500
# ANALYSIS_MAX_WORKERS=2

# --- Paths ---
# UPLOAD_FOLDER=uploads
# REPORTS_FOLDER=reports
# DATABASE_PATH=soundshield.db

# --- Audio Processing ---
# AUDIO_SAMPLE_RATE=22050
# AUDIO_CALIBRATION_SECONDS=30.0
# AUDIO_SEGMENT_LENGTH=5.0

# --- Cry Detection ---
# CRY_ENERGY_THRESHOLD=0.08
# CRY_FREQ_MIN=200
# CRY_FREQ_MAX=800
# CRY_RESPONSE_WINDOW=10.0

# --- Violence Detection ---
# VIOLENCE_MIN_ENERGY_GATE=0.05
# VIOLENCE_SHOUTING_ENERGY=0.25
# VIOLENCE_AGGRESSIVE_ENERGY=0.2
# VIOLENCE_THREATENING_ENERGY=0.18

# --- Emotion Detection ---
# EMOTION_CONFIDENCE_THRESHOLD=0.6
# EMOTION_ANGER_ENERGY=0.15
# EMOTION_AGGRESSION_ENERGY=0.2

# --- Neglect Detection ---
# NEGLECT_UNANSWERED_CRY_DURATION=30.0
# NEGLECT_MIN_CRY_DURATION=5.0
# NEGLECT_RESPONSE_WINDOW=15.0
# NEGLECT_PROLONGED_SILENCE_DURATION=120.0

# --- ML Models ---
# USE_ADVANCED_MODELS=true
# WHISPER_MODEL=base
# HUBERT_MODEL=superb/hubert-large-superb-er

# --- Data Retention ---
# DATA_RETENTION_DAYS=90

# --- Language ---
# LANGUAGE_DEFAULT=en
# LANGUAGE_WORDS_FILE=inappropriate_words.json

# --- Pipeline ---
# MAX_AUDIO_LENGTH=3600
# MIN_AUDIO_LENGTH=1
